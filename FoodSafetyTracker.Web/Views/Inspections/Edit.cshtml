@using FoodSafetyTracker.Web.Helpers
@model FoodSafetyTracker.Domain.Entities.Inspection

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Inspection</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group">
                <label asp-for="PremisesId" class="control-label"></label>
                <select asp-for="PremisesId" class="form-control" asp-items="ViewBag.PremisesId">
                    <option value="">-- Select Premises --</option>
                </select>
                <span asp-validation-for="PremisesId" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="InspectionDate" class="control-label"></label>
                <input asp-for="InspectionDate" class="form-control" type="date" />
                <span asp-validation-for="InspectionDate" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Score" class="control-label"></label>
                <input asp-for="Score" class="form-control" id="Score" min="0" max="100" step="1" />
                <span asp-validation-for="Score" class="text-danger"></span>
                <small class="text-muted">Score must be between 0 and 100</small>
            </div>
            
            <div class="form-group">
                <label asp-for="Outcome" class="control-label"></label>
                <input asp-for="Outcome" class="form-control" id="Outcome" readonly />
                <span asp-validation-for="Outcome" class="text-danger"></span>
                <small class="text-muted">Outcome is automatically calculated based on score (Pass ≥ 60, Fail ≤ 59)</small>
            </div>
            
            <div class="form-group">
                <label asp-for="Notes" class="control-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            
            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        // Auto-update Outcome based on Score
        const scoreInput = document.getElementById('Score');
        const outcomeField = document.getElementById('Outcome');
        
        function updateOutcome() {
            var score = parseInt(scoreInput.value) || 0;
            
            if (score >= 60) {
                outcomeField.value = 'Pass';
                outcomeField.className = 'form-control bg-success text-white';
            } else {
                outcomeField.value = 'Fail';
                outcomeField.className = 'form-control bg-danger text-white';
            }
        }
        
        if (scoreInput) {
            scoreInput.addEventListener('input', updateOutcome);
            // Trigger on page load to set initial Outcome based on existing Score
            updateOutcome();
        }
    </script>
}